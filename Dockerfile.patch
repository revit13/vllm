FROM vllm/vllm-openai:v0.16.0

# Base image already contains all compiled .so extensions for v0.16.0.
# We only overwrite the Python files that have debug log patches.
# No recompilation needed — build is fast (seconds).
#
# Find the installed vllm path:
#   docker run --rm vllm/vllm-openai:v0.16.0 python -c "import vllm; print(vllm.__file__)"
# Typically: /usr/local/lib/python3.12/dist-packages/vllm/

ARG VLLM_SITE=/usr/local/lib/python3.12/dist-packages/vllm

# Overwrite only the patched files (git checkout v0.16.0 ensures compatibility)
COPY vllm/v1/core/encoder_cache_manager.py                      ${VLLM_SITE}/v1/core/encoder_cache_manager.py
COPY vllm/v1/core/kv_cache_utils.py                             ${VLLM_SITE}/v1/core/kv_cache_utils.py
COPY vllm/v1/worker/gpu_model_runner.py                         ${VLLM_SITE}/v1/worker/gpu_model_runner.py
COPY vllm/v1/worker/gpu/mm/encoder_runner.py                    ${VLLM_SITE}/v1/worker/gpu/mm/encoder_runner.py
COPY vllm/distributed/ec_transfer/ec_connector/example_connector.py  ${VLLM_SITE}/distributed/ec_transfer/ec_connector/example_connector.py
COPY vllm/v1/engine/input_processor.py                          ${VLLM_SITE}/v1/engine/input_processor.py
COPY vllm/multimodal/processing/processor.py                    ${VLLM_SITE}/multimodal/processing/processor.py

